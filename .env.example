# Copy to .env. Never commit .env or real provider credentials.
APP_ENV=production
COOKIE_SECURE=true
HOST=0.0.0.0
PORT=9900
# Provider HTTP(S)_PROXY / ALL_PROXY variables are honoured by default. Set
# false only when the service must make direct outbound connections.
PROVIDER_TRUST_ENV=true
DATABASE_PATH=/data/models_router.db
TRUSTED_HOSTS=router.example.com
CADDY_DOMAIN=router.example.com
CADDY_EMAIL=ops@example.com
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-new-fernet-key
# Generate with: openssl rand -hex 32. Enter this value in the first-account Web form.
BOOTSTRAP_TOKEN=replace-with-a-random-bootstrap-token
# Optional local-only redaction. If LOCAL_REDACTOR_MODEL_PATH is empty, the backend
# downloads openai-mirror/privacy-filter from ModelScope into LOCAL_REDACTOR_CACHE_DIR.
# Redaction text is never sent to a Provider.
# LOCAL_REDACTOR_MODEL_PATH=/models/openai/privacy-filter
LOCAL_REDACTOR_CACHE_DIR=/data/modelscope
LOCAL_REDACTOR_AUTO_DOWNLOAD=true
# LOCAL_CHINESE_NER_MODEL_PATH=/models/chinese-ner
# LOCAL_REDACTOR_DEVICE=cpu
# LOCAL_REDACTOR_MIN_SCORE=0.5
MAX_MESSAGE_CHARS=200000
# Optional local GGUF classifier/router; install with: uv sync --extra local-gguf
# LOCAL_CLASSIFIER_MODEL_PATH=/models/classifier.gguf
# LOCAL_GGUF_CHAT_FORMAT=chatml
# LOCAL_GGUF_CONTEXT_TOKENS=4096
# LOCAL_GGUF_GPU_LAYERS=0
# LOCAL_GGUF_THREADS=0
