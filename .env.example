# Copy to .env. Never commit .env or real provider credentials.
APP_ENV=production
COOKIE_SECURE=true
DATABASE_PATH=/data/models_router.db
TRUSTED_HOSTS=router.example.com
CADDY_DOMAIN=router.example.com
CADDY_EMAIL=ops@example.com
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-new-fernet-key
# Generate with: openssl rand -hex 32. Enter this value in the first-account Web form.
BOOTSTRAP_TOKEN=replace-with-a-random-bootstrap-token
# Optional local GGUF redactor/classifier. These paths are read only by the backend;
# install with: uv sync --extra local-gguf
# LOCAL_REDACTOR_MODEL_PATH=/models/redactor.gguf
# LOCAL_CLASSIFIER_MODEL_PATH=/models/classifier.gguf
# LOCAL_GGUF_CHAT_FORMAT=chatml
# LOCAL_GGUF_CONTEXT_TOKENS=4096
# LOCAL_GGUF_GPU_LAYERS=0
# LOCAL_GGUF_THREADS=0
